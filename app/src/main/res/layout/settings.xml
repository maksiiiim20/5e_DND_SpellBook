<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="50dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="@color/BackgroundColor">

    <TextView
        android:id="@+id/SettingsTitle"
        android:text="Settings"
        android:textColor="@color/TextColor"
        android:textStyle="bold"
        android:textSize="24sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/BackgroundColorSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/SettingsTitle"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/BackgroundColourLabel"
            android:textSize="18sp"
            android:textColor="@color/TextColor"
            android:text="Choose background color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/PickBackgroundColorButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/border_background"
            android:text="Pick color"
            app:layout_constraintTop_toTopOf="@id/BackgroundColourLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/BackgroundColourLabel"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/BorderColorSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/BackgroundColorSelect"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/BorderColourLabel"
            android:textSize="18sp"
            android:textColor="@color/TextColor"
            android:text="Choose border color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/PickBorderColorButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/border_color_preview"
            android:text="Pick color"
            app:layout_constraintTop_toTopOf="@id/BorderColourLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/BorderColourLabel"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/TextColorSelect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/BorderColorSelect"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/TextColourLabel"
            android:textSize="18sp"
            android:textColor="@color/TextColor"
            android:text="Choose text color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/PickTextColorButton"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:background="@drawable/text_color_preview"
            android:text="Pick color"
            app:layout_constraintTop_toTopOf="@id/TextColourLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/TextColourLabel"/>

    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.constraintlayout.widget.ConstraintLayout>